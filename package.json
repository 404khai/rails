{
  "name": "rails",
  "version": "1.0.0",
  "description": "Developer-first virtual account infrastructure layer built on Nomba.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "start": "node dist/src/server.js",
    "start:worker": "node dist/src/worker.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/404khai/rails.git"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "bugs": {
    "url": "https://github.com/404khai/rails/issues"
  },
  "homepage": "https://github.com/404khai/rails#readme",
  "dependencies": {
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^6.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^26.1.0",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
